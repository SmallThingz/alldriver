# Copy to a private file and pass to:
# zig build tools -- matrix-ga --config <file>
# Required for signed reports in strict GA mode.
MATRIX_GPG_KEY_ID="YOUR_GPG_KEY_ID"

# Linux run mode: local|ssh
LINUX_MODE="local"
# LINUX_SSH_HOST="user@linux-vm"
# LINUX_SSH_PORT="2222"
# LINUX_REPO_PATH="/home/user/projects/zig/browser_driver"

# Windows run mode: local|ssh
WINDOWS_MODE="ssh"
WINDOWS_SSH_HOST="user@windows-vm"
WINDOWS_SSH_PORT="2223"
# Use POSIX style path if OpenSSH shell provides one.
WINDOWS_REPO_PATH="/c/Users/user/projects/zig/browser_driver"

# macOS run mode: local|ssh
MACOS_MODE="ssh"
MACOS_SSH_HOST="user@macos-vm"
MACOS_SSH_PORT="2224"
MACOS_REPO_PATH="/Users/user/projects/zig/browser_driver"
